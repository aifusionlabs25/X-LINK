}

.hub-redesign .dojo-telemetry-header,
.hub-redesign .dojo-diagnostics-panel,
.hub-redesign .dojo-neural-link,
.hub-redesign .review-progress-container {
    border-radius: 22px;
}

.hub-redesign .dojo-neural-link {
