}

.hub-redesign .neural-header,
.hub-redesign .mel-card-header,
.hub-redesign .mel-persona-header {
    background: rgba(255,255,255,0.04);
}

.hub-redesign .review-progress-container,
.hub-redesign .mel-status-bar {
    background: rgba(240, 179, 91, 0.08);
    border: 1px solid rgba(240, 179, 91, 0.18);
}

.hub-redesign .progress-track,
.hub-redesign .mel-progress-bar {
