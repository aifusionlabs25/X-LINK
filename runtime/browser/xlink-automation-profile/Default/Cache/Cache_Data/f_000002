.hub-redesign .config-options-list {
    gap: 16px 24px;
}

.hub-redesign .cb-container {
    color: var(--text-dim);
}

.hub-redesign .checkmark {
    border-radius: 6px;
}

.hub-redesign .health-grid {
    flex-wrap: wrap;
}

.hub-redesign .health-item {
    color: var(--text-dim);
}

.hub-redesign .history-item,
.hub-redesign .results-placeholder,
.hub-redesign .mel-placeholder,
.hub-redesign .neural-bubble,
.hub-redesign .message,
.hub-redesign .patch-comparison-box {
