/* X-LINK COMMAND HUB v3 — Modern Glassmorphism System */
:root {
    --gold: #d4af37;
    --accent: #ffd700;
    --bg-dark: #0a0a0b;
    --card-bg: rgba(20, 20, 22, 0.7);
    --glass-bg: rgba(255, 255, 255, 0.03);
    --border: rgba(212, 175, 55, 0.2);
    --text: #e0e0e0;
    --text-dim: #a0a0a0;
    --success: #10b981;
    --warning: #f59e0b;
    --error: #ef4444;
}

* { box-sizing: border-box; margin: 0; padding:0; }

body {
    background-color: var(--bg-dark);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
    height: 100vh;
    display: flex;
}

.ambient-glow {
    position: fixed;
    top: -20%;
    left: -10%;
    width: 60vw;
    height: 60vh;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.05) 0%, transparent 70%);
    z-index: -1;
    pointer-events: none;
}

/* SIDEBAR LAYOUT */
.sidebar {
    width: 250px;
    background: rgba(10, 10, 12, 0.95);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 30px 0;
    backdrop-filter: blur(20px);
}

.sidebar-logo {
    padding: 0 25px;
    margin-bottom: 40px;
    display: flex;
    align-items: center;
    gap: 12px;
}
.sidebar-logo .sidebar-icon { font-size: 1.5rem; }
.sidebar-logo .sidebar-label { font-family: 'Cinzel', serif; font-weight: 700; font-size: 1.1rem; color: var(--gold); }

.sidebar-section-label {
    padding: 0 25px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    margin: 20px 0 10px;
}

.sidebar-item {
    padding: 12px 25px;
    display: flex;
    align-items: center;
    gap: 15px;
    cursor: pointer;
    transition: all 0.2s;
    border-left: 3px solid transparent;
}

.sidebar-item:hover {
    background: rgba(212, 175, 55, 0.05);
    color: var(--gold);
    border-left-color: var(--gold);
}

.sidebar-item .sidebar-icon { width: 20px; font-size: 1.1rem; opacity: 0.7; }
.sidebar-item .sidebar-label { font-size: 0.85rem; font-weight: 500; }

.sidebar-status { margin-top: 5px; opacity: 0.8; }
.sidebar-internal { opacity: 0.6; }

/* MAIN CONTENT */
.main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    position: relative;
    padding: 0 40px 100px;
}

.workspace-pane { display: none; width: 100%; }
.workspace-pane.active { display: block; }

.sidebar-item.active-tool {
    background: rgba(212, 175, 55, 0.1);
    color: var(--gold);
    border-left-color: var(--gold);
}

.hub-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 40px 0;
    margin-bottom: 20px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
}

.header-left .tag {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-dim);
    margin-bottom: 8px;
    display: block;
}

.header-left h1 {
    font-family: 'Cinzel', serif;
    font-size: 1.8rem;
    letter-spacing: 0.05em;
    background: linear-gradient(135deg, #fff 0%, var(--gold) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: flex;
    align-items: center;
    gap: 15px;
}

.version-badge {
    font-family: 'Inter';
    font-size: 0.6rem;
    padding: 2px 6px;
    background: rgba(212, 175, 55, 0.2);
    border: 1px solid var(--gold);
    color: var(--gold);
    border-radius: 4px;
    vertical-align: middle;
}

.header-right.meta {
    display: flex;
    gap: 30px;
    font-family: 'Outfit', sans-serif;
    text-align: right;
}

.meta-item { display: flex; flex-direction: column; gap: 4px; }
.meta-label { font-size: 0.6rem; text-transform: uppercase; color: var(--text-dim); }
.meta-value { font-size: 0.85rem; font-weight: 700; }

.pulse-green { color: var(--success); }
.pulse-green::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--success);
    border-radius: 50%;
    margin-right: 8px;
    box-shadow: 0 0 10px var(--success);
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0% { opacity: 0.5; }
    50% { opacity: 1; }
    100% { opacity: 0.5; }
}

/* CARDS & GRIDS */
.sloane-desk-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 40px;
    backdrop-filter: blur(40px);
    margin-bottom: 40px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.3);
}

.premium-serif { font-family: 'Cinzel', serif; }
.gold-text { color: var(--gold); }

.card-header { display: flex; align-items: center; gap: 20px; margin-bottom: 30px; }
/* CHAT OVERLAY STYLE */
.chat-container {
    position: fixed;
    top: 18px;
    right: 18px;
    width: min(460px, calc(100vw - 28px));
    height: calc(100vh - 36px);
    max-height: 920px;
    background:
        linear-gradient(180deg, rgba(27, 31, 37, 0.94) 0%, rgba(15, 19, 25, 0.98) 100%);
    border: 1px solid rgba(242, 173, 94, 0.2);
    border-radius: 28px;
    backdrop-filter: blur(32px);
    display: flex;
    flex-direction: column;
    z-index: 1000;
    box-shadow:
        0 24px 70px rgba(0,0,0,0.48),
        inset 0 1px 0 rgba(255,255,255,0.05);
    transform: translateX(24px) scale(0.985);
    opacity: 0;
    pointer-events: none;
    transition: all 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
}

.chat-container::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
        radial-gradient(circle at top left, rgba(242, 173, 94, 0.16), transparent 38%),
        radial-gradient(circle at bottom right, rgba(91, 140, 255, 0.12), transparent 34%);
    pointer-events: none;
}

.chat-container.active {
    transform: translateX(0) scale(1);
    opacity: 1;
    pointer-events: all;
}

.chat-header {
    position: relative;
    z-index: 1;
    padding: 18px 20px 14px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
}

.chat-profile-header {
    display: flex;
    align-items: center;
    gap: 12px;
}

.chat-status-dot {
    width: 10px;
    height: 10px;
    background: #444;
    border-radius: 50%;
}

.chat-status-dot.active {
    background: var(--success);
    box-shadow: 0 0 10px var(--success);
}

.chat-title {
    font-size: 1rem;
    font-weight: 700;
    color: #ffe8bf;
    display: block;
}

.chat-heading-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.chat-subtitle {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.58);
    letter-spacing: 0.04em;
}

.close-chat {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    color: #f6ead1;
    font-size: 0.95rem;
    cursor: pointer;
    border-radius: 12px;
    padding: 8px 12px;
    transition: all 0.2s ease;
}

.close-chat:hover {
    border-color: rgba(242, 173, 94, 0.3);
    background: rgba(242, 173, 94, 0.12);
}

.chat-toolbar {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 10px;
    padding: 14px 20px 10px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    flex-wrap: wrap;
}

.chat-chip {
    border: 1px solid rgba(242, 173, 94, 0.16);
    background: rgba(255,255,255,0.03);
    color: #f0dcb6;
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: all 0.2s ease;
}

.chat-chip:hover {
    border-color: rgba(242, 173, 94, 0.34);
    background: rgba(242, 173, 94, 0.12);
}

.chat-messages {
    position: relative;
    z-index: 1;
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 18px 18px 10px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    scrollbar-width: thin;
    scrollbar-color: rgba(242, 173, 94, 0.35) transparent;
}

.message {
    max-width: 92%;
    padding: 12px 14px;
    border-radius: 18px;
    font-size: 0.92rem;
    line-height: 1.55;
    overflow-wrap: anywhere;
    word-break: break-word;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
}

.message.user {
    background: linear-gradient(180deg, rgba(54, 64, 80, 0.88), rgba(39, 48, 63, 0.9));
    align-self: flex-end;
    border: 1px solid rgba(255,255,255,0.06);
    border-bottom-right-radius: 4px;
}

.message.sloane {
    background: linear-gradient(180deg, rgba(49, 47, 40, 0.94), rgba(38, 40, 39, 0.96));
    border: 1px solid rgba(242, 173, 94, 0.22);
    align-self: flex-start;
    border-bottom-left-radius: 4px;
}

.message-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
}

.message-role {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 233, 192, 0.7);
    font-weight: 800;
}

.message-content {
    white-space: pre-wrap;
    color: rgba(249, 244, 233, 0.94);
}

.message.sloane .message-content {
    color: #f3ede1;
}

.chat-input-area {
    position: relative;
    z-index: 1;
    padding: 14px 18px 18px;
    border-top: 1px solid rgba(255,255,255,0.05);
    display: flex;
    align-items: flex-end;
    gap: 10px;
    background: linear-gradient(180deg, rgba(19, 23, 30, 0.76), rgba(13, 16, 20, 0.92));
}

.chat-input-area textarea {
    flex: 1;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    color: #fff;
    padding: 14px 16px;
    font-size: 0.92rem;
    outline: none;
    resize: none;
    min-height: 58px;
    max-height: 160px;
    font-family: 'Manrope', sans-serif;
    line-height: 1.45;
    overflow-y: auto;
}

.chat-action-stack {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 112px;
}

.chat-input-area textarea:focus {
    border-color: rgba(242, 173, 94, 0.45);
    box-shadow: 0 0 0 4px rgba(242, 173, 94, 0.08);
}

.chat-secondary-btn {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: #f6ead1;
    font-size: 0.84rem;
    font-weight: 800;
    cursor: pointer;
    border-radius: 14px;
    padding: 0 16px;
    min-height: 42px;
    transition: all 0.2s ease;
}

.chat-secondary-btn:hover {
    border-color: rgba(242, 173, 94, 0.28);
    background: rgba(242, 173, 94, 0.1);
}

.chat-secondary-btn.danger:hover {
    border-color: rgba(239, 68, 68, 0.3);
    background: rgba(239, 68, 68, 0.12);
}

.chat-input-area button {
    background: linear-gradient(180deg, #f4b66e, #e19456);
    border: 1px solid rgba(255,255,255,0.08);
    color: #17120c;
    font-size: 0.95rem;
    font-weight: 800;
    cursor: pointer;
    border-radius: 16px;
    padding: 0 22px;
    min-height: 58px;
    box-shadow: 0 10px 24px rgba(225, 148, 86, 0.18);
}

.chat-input-area button:hover {
    filter: brightness(1.04);
}

.chat-messages::-webkit-scrollbar {
    width: 10px;
}

.chat-messages::-webkit-scrollbar-thumb {
    background: rgba(242, 173, 94, 0.28);
    border-radius: 999px;
    border: 2px solid transparent;
    background-clip: padding-box;
}

.chat-messages::-webkit-scrollbar-track {
    background: transparent;
}

@media (max-width: 1100px) {
    .chat-container {
        top: auto;
        bottom: 14px;
        right: 14px;
        width: min(480px, calc(100vw - 20px));
        height: min(72vh, 760px);
    }
}

@media (max-width: 720px) {
    .chat-container {
        inset: 10px;
        width: auto;
        height: auto;
        max-height: none;
        border-radius: 22px;
    }

    .chat-toolbar {
        gap: 8px;
    }

    .chat-chip {
        font-size: 0.68rem;
    }

    .chat-action-stack {
        min-width: 96px;
    }
}

/* INTERVENTION OVERLAY */
.intervention-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0,0,0,0.8);
    backdrop-filter: blur(10px);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
}

.intervention-card {
    background: #111;
    border: 2px solid var(--error);
    border-radius: 24px;
    padding: 40px;
    width: 450px;
    text-align: center;
    box-shadow: 0 0 50px rgba(239, 68, 68, 0.2);
}

.intervention-icon { font-size: 3rem; margin-bottom: 20px; }
.intervention-title { font-family: 'Cinzel'; color: var(--error); margin-bottom: 15px; }
.intervention-service { color: var(--gold); font-weight: 700; margin-bottom: 5px; }
.intervention-issue { color: #fff; font-size: 1.1rem; font-weight: 600; margin-bottom: 15px; }
.intervention-message { color: var(--text-dim); margin-bottom: 25px; line-height: 1.5; }
.intervention-resume-btn {
    background: var(--success);
    color: #000;
    border: none;
    padding: 15px 30px;
    border-radius: 12px;
    font-weight: 700;
    cursor: pointer;
}
.cos-badge {
    font-size: 0.6rem;
    font-weight: 800;
    padding: 3px 8px;
    background: var(--gold);
    color: #000;
    border-radius: 40px;
    display: inline-block;
    vertical-align: middle;
    margin-left: 10px;
}

.briefing-quote {
    font-size: 1.2rem;
    font-style: italic;
    color: var(--text);
    margin-bottom: 30px;
    line-height: 1.6;
    border-left: 3px solid var(--gold);
    padding-left: 20px;
}

.dept-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
}

.dept-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 25px;
}

.dept-card h3 {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 15px;
    letter-spacing: 0.1em;
}

.dept-card p { font-size: 0.9rem; line-height: 1.5; color: var(--text); }

.priority-list {
    margin-top: 15px;
    padding-left: 0;
    list-style: none;
    font-size: 0.8rem;
    color: var(--gold);
}
.priority-list li { margin-bottom: 6px; }
.priority-list li::before { content: '→ '; }

/* DOJO CONSOLE WORKSPACE */
.dojo-console {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 24px;
    backdrop-filter: blur(40px);
    margin-bottom: 40px;
    overflow: hidden;
    animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}

.dojo-nav {
    display: flex;
    background: rgba(0, 0, 0, 0.3);
    padding: 10px 20px;
    gap: 10px;
    border-bottom: 1px solid var(--border);
    position: relative;
}

.dojo-tab {
    background: transparent;
    border: none;
    color: var(--text-dim);
    font-family: 'Outfit';
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    padding: 12px 25px;
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 8px;
}

.dojo-tab:hover { color: var(--text); background: rgba(255,255,255,0.05); }
.dojo-tab.active { color: var(--gold); background: rgba(212, 175, 55, 0.1); }

.dojo-close {
    margin-left: auto;
    background: transparent;
    border: none;
    color: var(--text-dim);
    font-size: 1.5rem;
    cursor: pointer;
}

.dojo-pane { display: none; padding: 40px; height: 600px; overflow-y: auto; }
.dojo-pane.active { display: block; }

/* RUN TAB LAYOUT */
.dojo-layout-split { display: grid; grid-template-columns: 1fr 350px; gap: 40px; }
.config-group { margin-bottom: 20px; }
.config-group label { display: block; font-size: 0.65rem; text-transform: uppercase; color: var(--text-dim); margin-bottom: 8px; font-weight: 700; }

.premium-input {
    width: 100%;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    padding: 12px 15px;
    font-family: 'Inter';
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
}

.premium-input:focus { border-color: var(--gold); }

.config-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }

.config-options-list {
    margin: 30px 0;
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
}

/* Dojo Status Panel */
.dojo-status-panel {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: 15px;
    margin: 20px 0;
}
.status-header {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.1rem;
    color: var(--gold);
    margin-bottom: 12px;
    opacity: 0.8;
}
.health-grid {
    display: flex;
    gap: 20px;
    font-size: 0.75rem;
    font-family: 'Inter', sans-serif;
}
.health-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--text-muted);
}
.health-item .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #444;
}
.health-item.ok .dot { background: var(--success); box-shadow: 0 0 5px var(--success); }
.health-item.error .dot { background: var(--danger); box-shadow: 0 0 5px var(--danger); }
.health-item .val { color: #fff; font-weight: 600; }

/* Progress Bar for Reviews */
.review-progress-container {
    margin-top: 20px;
    padding: 15px;
    background: rgba(255, 215, 0, 0.05);
    border: 1px solid rgba(255, 215, 0, 0.1);
    border-radius: 8px;
}

.progress-label {
    font-size: 0.85rem;
    color: var(--gold);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: flex;
    justify-content: space-between;
}

.progress-track {
    height: 8px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    overflow: hidden;
}

.progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #d4af37, #f9d71c);
    box-shadow: 0 0 15px rgba(255, 215, 0, 0.3);
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
}

.progress-fill::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    animation: progress-shine 2s infinite;
}

@keyframes progress-shine {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
}
/* Checkbox Style */
.cb-container {
    display: block;
    position: relative;
    padding-left: 30px;
    cursor: pointer;
    font-size: 0.8rem;
    color: var(--text-dim);
    user-select: none;
}
.cb-container input { position: absolute; opacity: 0; cursor: pointer; height: 0; width: 0; }
.checkmark {
    position: absolute;
    top: 0;
    left: 0;
    height: 18px;
    width: 18px;
    background-color: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    border-radius: 4px;
}
.cb-container:hover input ~ .checkmark { background-color: rgba(255,255,255,0.1); }
.cb-container input:checked ~ .checkmark { background-color: var(--gold); }
.checkmark:after {
    content: "";
    position: absolute;
    display: none;
}
.cb-container input:checked ~ .checkmark:after { display: block; }
.cb-container .checkmark:after {
    left: 6px;
    top: 2px;
    width: 4px;
    height: 9px;
    border: solid black;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
}

.agent-multi-select-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
    margin-top: 10px;
    background: rgba(0,0,0,0.2);
    padding: 15px;
    border: 1px solid var(--border);
    border-radius: 8px;
}
.agent-select-cb {
    font-size: 0.85rem;
    color: var(--text);
}

.dojo-actions { display: flex; gap: 20px; }
.dojo-primary-btn {
    background: var(--gold);
    color: #000;
    border: none;
    padding: 15px 40px;
    font-family: 'Outfit';
    font-weight: 700;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s;
    flex: 1;
}
.dojo-primary-btn:hover { background: var(--accent); transform: translateY(-2px); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }

.dojo-secondary-btn {
