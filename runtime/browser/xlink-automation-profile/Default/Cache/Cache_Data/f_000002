/* ── MEL Progress Timeline ─────────────────────────────────── */

.mel-progress-panel {
    padding: 30px 40px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
}

.mel-progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.mel-progress-bar-container {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    max-width: 350px;
}

.mel-progress-bar {
    flex: 1;
    height: 8px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    overflow: hidden;
}

.mel-progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #d4af37, #f9d71c);
    box-shadow: 0 0 15px rgba(255, 215, 0, 0.3);
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
}

.mel-progress-fill::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    animation: progress-shine 2s infinite;
}

.mel-progress-pct {
    font-family: 'Outfit';
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--gold);
    min-width: 35px;
    text-align: right;
}

.mel-timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-height: 400px;
    overflow-y: auto;
    padding-right: 10px;
}

.mel-step {
    display: flex;
    align-items: flex-start;
    gap: 15px;
    padding: 12px 0;
    position: relative;
    animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
}

/* Connecting line between steps */
.mel-step::before {
    content: '';
    position: absolute;
    left: 13px;
    top: 36px;
    bottom: -12px;
    width: 2px;
    background: rgba(255,255,255,0.08);
}

.mel-step:last-child::before {
    display: none;
}

.mel-step-done::before {
    background: rgba(16, 185, 129, 0.3);
}

.mel-step-active::before {
    background: rgba(212, 175, 55, 0.4);
}

.mel-step-indicator {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    flex-shrink: 0;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
}

.mel-step-done .mel-step-indicator {
    background: rgba(16, 185, 129, 0.15);
    border-color: rgba(16, 185, 129, 0.3);
}

.mel-step-active .mel-step-indicator {
    background: rgba(212, 175, 55, 0.15);
    border-color: var(--gold);
    box-shadow: 0 0 12px rgba(212, 175, 55, 0.3);
}

.mel-step-error .mel-step-indicator {
    background: rgba(239, 68, 68, 0.15);
    border-color: rgba(239, 68, 68, 0.4);
}

.mel-step-content {
    flex: 1;
    min-width: 0;
}

.mel-step-title {
    font-family: 'Outfit';
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--text-dim);
    margin-bottom: 4px;
}

.mel-step-done .mel-step-title {
    color: var(--success);
}

.mel-step-active .mel-step-title {
    color: var(--gold);
}

.mel-step-error .mel-step-title {
    color: var(--error);
}

.mel-step-detail {
    font-size: 0.85rem;
    color: var(--text);
    line-height: 1.5;
}

.mel-step-time {
    font-size: 0.65rem;
    color: var(--text-dim);
    margin-top: 3px;
}

.mel-step-score {
    display: inline-block;
    background: rgba(212, 175, 55, 0.15);
    color: var(--gold);
    padding: 2px 8px;
    border-radius: 6px;
    font-family: 'Outfit';
    font-weight: 700;
    font-size: 0.8rem;
    margin-left: 8px;
}

.mel-step-spinner {
    display: inline-block;
    color: var(--gold);
    animation: spinnerPulse 1s ease-in-out infinite;
}

@keyframes spinnerPulse {
    0% { opacity: 0.3; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.2); }
    100% { opacity: 0.3; transform: scale(0.8); }
}

/* MEL Persona Viewer & Copy UI */
.mel-persona-viewer {
    margin-top: 20px;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    display: none; /* Toggleable via JS */
}

.mel-persona-header {
    background: rgba(212, 175, 55, 0.1);
    padding: 10px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border);
}

.mel-persona-header span {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
}

.mel-copy-btn {
    background: var(--gold);
    color: #000;
    border: none;
    padding: 4px 12px;
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
}

.mel-copy-btn:hover {
    background: #fff;
    transform: scale(1.05);
}

.mel-persona-content {
    padding: 20px;
    max-height: 400px;
    overflow-y: auto;
}

.mel-persona-content pre {
    white-space: pre-wrap;
    word-break: break-word;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.8rem;
    line-height: 1.5;
    color: #ccc;
}

.mel-view-toggle-btn {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--text-dim);
    padding: 8px 15px;
    border-radius: 8px;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    margin-top: 15px;
    transition: all 0.2s;
    width: 100%;
}

.mel-view-toggle-btn:hover {
    background: rgba(255,255,255,0.05);
    color: var(--gold);
    border-color: var(--gold);
}

/* Highlight Patch Sections */
.mel-persona-content pre b {
    color: var(--gold);
    background: rgba(212, 175, 55, 0.1);
    padding: 2px 4px;
    border-radius: 2px;
}

.agent-label {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 4px;
    letter-spacing: 0.05em;
}

.message-content {
    line-height: 1.4;
}

/* Specific Board Member Colors */
.message.board-ceo { border-left: 3px solid #ff00ff !important; }
.message.board-eng-manager { border-left: 3px solid #00ffff !important; }
.message.board-sales-lead { border-left: 3px solid #ffff00 !important; }
.message.board-ops-lead { border-left: 3px solid #00ff00 !important; }

.mel-stop-btn {
    background: linear-gradient(135deg, #ff4b2b 0%, #ff416c 100%) !important;
