/* ===== Mission Theater ===== */
.hub-redesign .mission-theater {
    position: relative;
    overflow: hidden;
    display: block;
    min-height: 420px;
    margin: 18px 0 22px;
    padding: 26px 28px 28px;
    border-radius: 28px;
    border: 1px solid rgba(240, 180, 92, 0.18);
    background:
        radial-gradient(circle at 15% 20%, rgba(255, 197, 95, 0.18), transparent 32%),
        radial-gradient(circle at 85% 20%, rgba(91, 145, 255, 0.12), transparent 30%),
        linear-gradient(135deg, rgba(22, 28, 38, 0.96), rgba(12, 17, 25, 0.92));
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.05),
        0 24px 70px rgba(0, 0, 0, 0.28);
}

.hub-redesign .mission-theater::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
        linear-gradient(90deg, transparent, rgba(255,255,255,0.035), transparent);
    transform: translateX(-100%);
    animation: missionSweep 9s linear infinite;
    pointer-events: none;
}

.hub-redesign .mission-theater-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    justify-content: space-between;
    align-items: start;
    gap: 18px;
    margin-bottom: 22px;
}

.hub-redesign .mission-kicker {
    display: inline-block;
    margin-bottom: 8px;
    font-size: 0.72rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 205, 119, 0.82);
}

.hub-redesign .mission-theater h3 {
    margin: 0;
    font-family: "Fraunces", serif;
    font-size: clamp(1.35rem, 1.8vw, 2rem);
    color: #fff2dc;
}

.hub-redesign .mission-theater-deck {
    margin: 10px 0 0;
    max-width: 720px;
    color: rgba(220, 228, 239, 0.74);
    line-height: 1.6;
}

.hub-redesign .mission-status-pill {
    align-self: center;
    padding: 10px 14px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.84);
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
}

.hub-redesign .mission-status-pill.phase-running,
.hub-redesign .mission-status-pill.phase-reporting,
.hub-redesign .mission-status-pill.phase-planning {
    color: #1d1404;
    background: linear-gradient(135deg, #ffcf84, #f0a85e);
    border-color: rgba(255, 214, 143, 0.72);
    box-shadow: 0 0 18px rgba(255, 187, 72, 0.26);
}

.hub-redesign .mission-status-pill.phase-completed {
    background: rgba(93, 205, 145, 0.16);
    border-color: rgba(93, 205, 145, 0.42);
    color: #97f7bb;
}

.hub-redesign .mission-status-pill.phase-failed {
    background: rgba(255, 104, 104, 0.14);
    border-color: rgba(255, 104, 104, 0.4);
    color: #ff9b9b;
}

.hub-redesign .mission-status-pill.phase-waiting_for_approval {
    background: rgba(123, 156, 255, 0.14);
    border-color: rgba(123, 156, 255, 0.34);
    color: #b6c8ff;
}

.hub-redesign .mission-rail {
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 22px;
    padding: 16px 14px;
    border-radius: 22px;
    background: rgba(8, 12, 18, 0.45);
    border: 1px solid rgba(255,255,255,0.045);
}

.hub-redesign .mission-rail::before {
    content: "";
    position: absolute;
    left: 7%;
    right: 7%;
    top: 36px;
    height: 2px;
    background: linear-gradient(90deg, rgba(255,255,255,0.08), rgba(255, 189, 92, 0.3), rgba(255,255,255,0.08));
}

.hub-redesign .mission-node {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: rgba(234, 238, 245, 0.65);
}

.hub-redesign .mission-node-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: rgba(255,255,255,0.18);
    box-shadow: 0 0 0 8px rgba(255,255,255,0.02);
    transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
}

.hub-redesign .mission-node-label {
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
}

.hub-redesign .mission-node.is-done .mission-node-dot {
    background: #80e6b0;
    box-shadow: 0 0 0 8px rgba(128, 230, 176, 0.12), 0 0 18px rgba(128, 230, 176, 0.35);
}

.hub-redesign .mission-node.is-active .mission-node-dot {
    background: #ffc974;
    transform: scale(1.2);
    box-shadow: 0 0 0 10px rgba(255, 201, 116, 0.13), 0 0 24px rgba(255, 201, 116, 0.42);
}

.hub-redesign .mission-node.is-waiting .mission-node-dot {
    background: #9eb8ff;
    box-shadow: 0 0 0 8px rgba(158, 184, 255, 0.1), 0 0 16px rgba(158, 184, 255, 0.24);
}

.hub-redesign .mission-node.is-error .mission-node-dot {
    background: #ff8d8d;
    box-shadow: 0 0 0 8px rgba(255, 141, 141, 0.1), 0 0 18px rgba(255, 141, 141, 0.34);
}

.hub-redesign .mission-pulse {
    position: absolute;
    top: 28px;
    left: 2%;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 220, 158, 0.96), rgba(255, 173, 87, 0.2));
    box-shadow: 0 0 22px rgba(255, 189, 92, 0.38);
    transform: translateX(-50%);
    transition: left 360ms ease;
}

.hub-redesign .mission-panels {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 18px;
    align-items: stretch;
}

.hub-redesign .mission-panel {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    min-height: 190px;
    padding: 18px 20px;
    border-radius: 22px;
    background: rgba(9, 14, 21, 0.56);
    border: 1px solid rgba(255,255,255,0.05);
}

.hub-redesign .mission-panel-label {
    margin-bottom: 14px;
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 205, 119, 0.82);
}

.hub-redesign .mission-job-meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 16px;
}

.hub-redesign .meta-chip {
    display: inline-block;
    margin-bottom: 6px;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(182, 195, 214, 0.65);
}

.hub-redesign .mission-detail {
    font-family: "Fraunces", serif;
    font-size: 1.1rem;
    line-height: 1.45;
    color: #fff0d7;
}

.hub-redesign .mission-subdetail {
    margin-top: 12px;
    color: rgba(205, 214, 227, 0.72);
    line-height: 1.5;
}

.hub-redesign .signal-bars {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
    margin-bottom: 14px;
}

.hub-redesign .signal-bars span {
    display: block;
    height: 42px;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(255, 204, 120, 0.75), rgba(69, 116, 255, 0.1));
    opacity: 0.38;
    transform-origin: bottom;
}

.hub-redesign .signal-bars.bars-live span {
    animation: signalDance 1.4s ease-in-out infinite;
}

.hub-redesign .signal-bars.bars-live span:nth-child(2) { animation-delay: 0.1s; }
.hub-redesign .signal-bars.bars-live span:nth-child(3) { animation-delay: 0.2s; }
.hub-redesign .signal-bars.bars-live span:nth-child(4) { animation-delay: 0.3s; }
.hub-redesign .signal-bars.bars-live span:nth-child(5) { animation-delay: 0.4s; }
.hub-redesign .signal-bars.bars-live span:nth-child(6) { animation-delay: 0.5s; }

.hub-redesign .mission-signal-list {
    display: grid;
    gap: 10px;
}

.hub-redesign .signal-line {
    padding: 10px 12px;
    border-radius: 14px;
    background: rgba(255,255,255,0.03);
    color: rgba(223, 230, 240, 0.78);
}

@keyframes signalDance {
    0%, 100% { transform: scaleY(0.35); opacity: 0.35; }
    50% { transform: scaleY(1); opacity: 1; }
}

@keyframes missionSweep {
    from { transform: translateX(-120%); }
    to { transform: translateX(140%); }
}

@media (max-width: 900px) {
    .hub-redesign .mission-theater {
        min-height: 0;
        padding: 22px 18px;
    }

    .hub-redesign .mission-theater-header {
        grid-template-columns: 1fr;
    }

    .hub-redesign .mission-panels,
    .hub-redesign .mission-job-meta,
    .hub-redesign .mission-rail {
        grid-template-columns: 1fr;
        display: grid;
    }

    .hub-redesign .mission-rail::before,
    .hub-redesign .mission-pulse {
        display: none;
    }

    .hub-redesign .mission-node {
        align-items: flex-start;
    }
}
