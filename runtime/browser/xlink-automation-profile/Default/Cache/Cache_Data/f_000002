    border-radius: 28px;
    border: 1px solid rgba(240, 107, 96, 0.28);
    background: linear-gradient(180deg, rgba(31, 16, 18, 0.96), rgba(22, 15, 17, 0.98));
}

.hub-redesign .intervention-icon {
    width: 84px;
    height: 84px;
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 24px;
    font-size: 0.9rem;
