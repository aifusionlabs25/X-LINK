    .hub-redesign {
        display: block;
    }

    .hub-redesign .sidebar {
        width: 100%;
        border-right: 0;
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .hub-redesign .main-content {
        padding: 0 18px 88px;
    }

    .hub-redesign .timeline-item,
    .hub-redesign .meta {
        grid-template-columns: 1fr;
        display: grid;
    }

    .hub-redesign .chat-container {
        right: 14px;
        left: 14px;
        width: auto;
        height: 64vh;
    }
