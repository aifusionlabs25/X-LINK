}
.heatmap-cell:hover { transform: scale(1.1); }
.heatmap-cell.pass { background: #10b981; box-shadow: 0 0 10px rgba(16, 185, 129, 0.3); }
.heatmap-cell.fail { background: #ef4444; box-shadow: 0 0 10px rgba(239, 68, 68, 0.3); }

.completion-stats {
